{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Profile data for the teacher",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "school": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "ModulAjar": {
      "title": "Modul Ajar",
      "description": "Learning module generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "curriculum": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "content": { "type": "string" }
      },
      "required": ["id", "userId", "title", "subject", "grade", "curriculum", "createdAt", "content"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "documents/{documentId}": {
      "schema": "ModulAjar",
      "description": "Collection of generated modules"
    }
  }
}
